# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Configuration
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=

# LLM Configuration
# Выбор провайдера: "gemini" (по умолчанию) или "ollama" (локальная модель)
LLM_PROVIDER=gemini

# Gemini (используется при LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Ollama (используется при LLM_PROVIDER=ollama)
# Публичный endpoint через reverse-proxy на glprod
OLLAMA_BASE_URL=https://gltournament.ru/ollama
OLLAMA_MODEL=qwen2.5:7b
# Basic-авторизация к reverse-proxy в формате "user:token"
OLLAMA_BASIC_AUTH=

# AI-суммаризация GitHub-событий (push) через LLM: true/false
SUMMARIZE_GITHUB_EVENTS=false

# Jira (дайджест канбана /jira, разбивка frontend/backend по исполнителям)
JIRA_BASE_URL=https://gltournament.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=KAN
# Подстроки displayName исполнителей (через запятую); первый — имя для дайджеста
JIRA_FRONTEND_USERS=Shpinat,Шпинат
JIRA_BACKEND_USERS=Mejaikin,Межайкин

# GlitchTip (раздел «активные ошибки» в утреннем дайджесте /digest)
GLITCHTIP_URL=https://glitch.gltournament.ru
GLITCHTIP_TOKEN=
GLITCHTIP_ORG=goodluck
GLITCHTIP_PROJECTS=backend

# Зависшие задачи Jira (/stale + авто раз в день). Время — МСК.
STALE_ENABLED=true
STALE_DAYS=7
STALE_HOUR=10
# Куда слать авто (пусто = PUSH_SUMMARY_CHAT_ID)
STALE_CHAT_ID=
STALE_THREAD_ID=

# Месячная сводка (/monthly + авто 1-го числа). Время — МСК.
MONTHLY_ENABLED=true
MONTHLY_HOUR=10
MONTHLY_CHAT_ID=
MONTHLY_THREAD_ID=

# Self-ping для поддержания инстанса тёплым на Render: true/false
SELF_PING_ENABLED=false

# Cursor Deeplink Configuration
# Путь к workspace репозитория goodluckv2 для генерации диплинков
# Пример: D:/Git/goodluckv2 или /home/user/projects/goodluckv2
GOODLUCK_WORKSPACE_PATH=

# HTTPS мост для диплинков Cursor (например GitHub Pages)
# Пример: https://raspizdiys.github.io/tgbotgithookv2
# Страница docs/index.html формирует cursor:// ссылку и делает redirect
BRIDGE_BASE_URL=

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:10000
TELEGRAM_ENABLE_POLLING=true

# Для локальной разработки раскомментируйте:
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
