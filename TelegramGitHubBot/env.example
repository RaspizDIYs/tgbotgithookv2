# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Configuration
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=

# LLM Configuration
# Выбор провайдера: "gemini" (по умолчанию) или "ollama" (локальная модель)
LLM_PROVIDER=gemini

# Gemini (используется при LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Ollama (используется при LLM_PROVIDER=ollama)
# Публичный endpoint через reverse-proxy на glprod
OLLAMA_BASE_URL=https://gltournament.ru/ollama
OLLAMA_MODEL=qwen2.5:7b
# Basic-авторизация к reverse-proxy в формате "user:token"
OLLAMA_BASIC_AUTH=

# AI-суммаризация GitHub-событий (push) через LLM: true/false
SUMMARIZE_GITHUB_EVENTS=false

# Cursor Deeplink Configuration
# Путь к workspace репозитория goodluckv2 для генерации диплинков
# Пример: D:/Git/goodluckv2 или /home/user/projects/goodluckv2
GOODLUCK_WORKSPACE_PATH=

# HTTPS мост для диплинков Cursor (например GitHub Pages)
# Пример: https://raspizdiys.github.io/tgbotgithookv2
# Страница docs/index.html формирует cursor:// ссылку и делает redirect
BRIDGE_BASE_URL=

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:10000
TELEGRAM_ENABLE_POLLING=true

# Для локальной разработки раскомментируйте:
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
